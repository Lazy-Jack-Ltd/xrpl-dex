{
  "name": "@xrpl-dex/core",
  "version": "0.1.0",
  "description": "Open source XRPL DEX — swap, order book, and liquidity tools for the XRP Ledger",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "xrpl",
    "xrp",
    "dex",
    "decentralized-exchange",
    "swap",
    "orderbook",
    "rlusd",
    "stablecoin"
  ],
  "author": "TokenCanvas",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/TokenCanvasIO/xrpl-dex"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "xrpl": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "dependencies": {
    "xrpl": "^4.1.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "react": "^18.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
